				Name="VCAppVerifierTool"
			/>
			<Tool
				Name="VCWebDeploymentTool"
			/>
			<Tool
				Name="VCPostBuildEventTool"
				Description="Copy Mel Scripts"
				CommandLine="copy          &quot;$(ProjectDir)..\..\MEL\*.mel&quot;          &quot;$(MAYAINSTALLPATH85)\scripts\others&quot;&#x0D;&#x0A;copy          &quot;$(TargetPath)&quot;          &quot;$(MAYAINSTALLPATH85)\bin\plug-ins\&quot;&#x0D;&#x0A;"
			/>
		</Configuration>
