				Name="VCLinkerTool"
				AdditionalOptions="/export:initializePlugin /export:uninitializePlugin "
				AdditionalDependencies="odbc32.lib odbccp32.lib Foundation.lib OpenMaya.lib"
				OutputFile="NiMultiShader60.mll"
				SuppressStartupBanner="TRUE"
				AdditionalLibraryDirectories="$(MAYAINSTALLPATH60)\lib"
				GenerateDebugInformation="TRUE"
				ImportLibrary="$(OutDir)\$(TargetName).lib"/>
			<Tool
				Name="VCMIDLTool"
				PreprocessorDefinitions="_DEBUG"
				MkTypLibCompatible="TRUE"/>
			<Tool
				Name="VCPostBuildEventTool"
				Description="Copy Mel Scripts"
				CommandLine="copy          &quot;$(ProjectDir)..\..\MEL\*.mel&quot;          &quot;$(MAYAINSTALLPATH60)\scripts\others&quot;
copy          &quot;$(TargetPath)&quot;          &quot;$(MAYAINSTALLPATH60)\bin\plug-ins\&quot;
"/>
