	<Configurations>
		<Configuration
			Name="Debug DLL Maya60|Win32"
			OutputDirectory="DebugDLL60"
			IntermediateDirectory="DebugDLL60"
			ConfigurationType="2"
			UseOfMFC="0"
			ATLMinimizesCRunTimeLibraryUsage="FALSE">
			<Tool
				Name="VCCLCompilerTool"
				Optimization="0"
				AdditionalIncludeDirectories="&quot;$(MAYAINSTALLPATH60)\include&quot;;..\..\..\..\..\..\sdk\Win32\Include"
				PreprocessorDefinitions="_DEBUG;WIN32;_WINDOWS;NT_PLUGIN;MAYA60;STRICT;NIDEBUG"
				RuntimeLibrary="3"
				ForceConformanceInForLoopScope="TRUE"
				UsePrecompiledHeader="2"
				WarningLevel="3"
				DebugInformationFormat="4"
				ForcedIncludeFiles="NiBuildConfiguration.h"/>
