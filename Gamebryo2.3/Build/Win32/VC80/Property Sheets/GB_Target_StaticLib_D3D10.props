<?xml version="1.0" encoding="utf-8"?>
<Project DefaultTargets="Build" ToolsVersion="4.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <ImportGroup Label="PropertySheets">
    <Import Project="GB_Target_StaticLib.props" />
  </ImportGroup>
  <PropertyGroup Label="UserMacros">
    <GB_Target_Filename>$(GB_Target_Path)\$(ProjectName)D3D10.lib</GB_Target_Filename>
  </PropertyGroup>
  <PropertyGroup>
    <_ProjectFileVersion>10.0.40219.1</_ProjectFileVersion>
    <OutDir>$(GB_Configuration_Name)$(GB_Target_Suffix)D3D10\</OutDir>
    <IntDir>$(GB_Configuration_Name)$(GB_Target_Suffix)D3D10\</IntDir>
  </PropertyGroup>
  <ItemGroup>
    <BuildMacro Include="GB_Target_Filename">
      <Value>$(GB_Target_Filename)</Value>
    </BuildMacro>
  </ItemGroup>
</Project>