<?xml version="1.0" encoding="utf-8"?>
<Project DefaultTargets="Build" ToolsVersion="4.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup Label="UserMacros">
    <GB_Configuration_Name>Debug</GB_Configuration_Name>
    <GB_DLL_Suffix>23VC80D</GB_DLL_Suffix>
    <GB_Tool_Plugin_Extension>dld</GB_Tool_Plugin_Extension>
    <GB_Shader_Library_Extension>.dl9</GB_Shader_Library_Extension>
    <GB_Shader_Parser_Extension>.dp9</GB_Shader_Parser_Extension>
  </PropertyGroup>
  <PropertyGroup>
    <_ProjectFileVersion>10.0.40219.1</_ProjectFileVersion>
  </PropertyGroup>
  <ItemDefinitionGroup>
    <ClCompile>
      <Optimization>Disabled</Optimization>
      <PreprocessorDefinitions>_DEBUG;NIDEBUG;%(PreprocessorDefinitions)</PreprocessorDefinitions>
      <MinimalRebuild>true</MinimalRebuild>
      <BasicRuntimeChecks>EnableFastChecks</BasicRuntimeChecks>
      <RuntimeLibrary>MultiThreadedDebugDLL</RuntimeLibrary>
      <DebugInformationFormat>EditAndContinue</DebugInformationFormat>
    </ClCompile>
  </ItemDefinitionGroup>
  <ItemGroup>
    <BuildMacro Include="GB_Configuration_Name">
      <Value>$(GB_Configuration_Name)</Value>
    </BuildMacro>
    <BuildMacro Include="GB_DLL_Suffix">
      <Value>$(GB_DLL_Suffix)</Value>
    </BuildMacro>
    <BuildMacro Include="GB_Tool_Plugin_Extension">
      <Value>$(GB_Tool_Plugin_Extension)</Value>
    </BuildMacro>
    <BuildMacro Include="GB_Shader_Library_Extension">
      <Value>$(GB_Shader_Library_Extension)</Value>
    </BuildMacro>
    <BuildMacro Include="GB_Shader_Parser_Extension">
      <Value>$(GB_Shader_Parser_Extension)</Value>
    </BuildMacro>
  </ItemGroup>
</Project>