<?xml version="1.0" encoding="utf-8"?>
<Project DefaultTargets="Build" ToolsVersion="4.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <ImportGroup Label="PropertySheets">
    <Import Project="GB_Target_DynamicLib.props" />
  </ImportGroup>
  <PropertyGroup Label="UserMacros">
    <GB_Target_Filename>$(GB_Target_Path)\$(ProjectName)DX9$(GB_DLL_Suffix).dll</GB_Target_Filename>
    <GB_Target_Import_Filename>$(GB_Target_Import_Path)\$(ProjectName)DX9$(GB_DLL_Suffix).lib</GB_Target_Import_Filename>
  </PropertyGroup>
  <PropertyGroup>
    <_ProjectFileVersion>10.0.40219.1</_ProjectFileVersion>
    <OutDir>$(GB_Configuration_Name)$(GB_Target_Suffix)DX9\</OutDir>
    <IntDir>$(GB_Configuration_Name)$(GB_Target_Suffix)DX9\</IntDir>
  </PropertyGroup>
  <ItemDefinitionGroup>
    <ClCompile>
      <PreprocessorDefinitions>_DX9;%(PreprocessorDefinitions)</PreprocessorDefinitions>
    </ClCompile>
  </ItemDefinitionGroup>
  <ItemGroup>
    <BuildMacro Include="GB_Target_Filename">
      <Value>$(GB_Target_Filename)</Value>
    </BuildMacro>
    <BuildMacro Include="GB_Target_Import_Filename">
      <Value>$(GB_Target_Import_Filename)</Value>
    </BuildMacro>
  </ItemGroup>
</Project>